# Cinefuse environment configuration — copy to .env.local for local dev.
# NEVER commit .env or .env.local. Both are gitignored.

# ---- Pubfuse SDK Client (provisioned at https://www.pubfuse.com/developer) ----
# Cinefuse runs as its own SDK Client; these values authenticate every request
# the cloud makes to Pubfuse on behalf of Cinefuse users.
PUBFUSE_API_BASE_URL=https://api.pubfuse.com
PUBFUSE_APP_ID=Cinefuse
PUBFUSE_CLIENT_ID=
PUBFUSE_CLIENT_SECRET=
PUBFUSE_HMAC_SECRET=

# ---- Cinefuse cloud ----
CINEFUSE_API_BASE_URL=http://localhost:4000
CINEFUSE_WEB_BASE_URL=http://localhost:3000

# ---- Postgres ----
DATABASE_URL=postgres://cinefuse:cinefuse@localhost:5432/cinefuse

# ---- Redis (BullMQ + RQ) ----
REDIS_URL=redis://localhost:6379

# ---- Render-worker provider keys (M1+) ----
# Leave blank in M0; M1 wires up fal.ai for clip generation.
FAL_API_KEY=
ELEVENLABS_API_KEY=
SUNO_API_KEY=
ANTHROPIC_API_KEY=

# ---- Apple StoreKit (M6) ----
APPLE_BUNDLE_ID=com.pubfuse.cinefuse
APPLE_SHARED_SECRET=
APPLE_VERIFY_RECEIPT_ENV=sandbox

# ---- Observability ----
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
