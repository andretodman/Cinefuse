# Cinefuse environment configuration — copy to .env.local for local dev.
# NEVER commit .env or .env.local. Both are gitignored.

# ---- Pubfuse SDK Client (provisioned at https://www.pubfuse.com/developer) ----
# Cinefuse runs as its own SDK Client; these values authenticate every request
# the cloud makes to Pubfuse on behalf of Cinefuse users.
PUBFUSE_API_BASE_URL=https://api.pubfuse.com
PUBFUSE_APP_ID=Cinefuse
PUBFUSE_CLIENT_ID=c8ab9fdd-f49a-45b8-864f-5f3519582bdf
PUBFUSE_CLIENT_SECRET=4e847ae5f41a41dcbb54626db908d6f82f666fbd523343618cf4bec5f5002ff9
PUBFUSE_HMAC_SECRET=

# ---- Cinefuse cloud ----
CINEFUSE_API_BASE_URL=http://localhost:4000
CINEFUSE_WEB_BASE_URL=http://localhost:3000

# ---- Postgres ----
#DATABASE_URL=postgres://cinefuse:cinefuse@localhost:5432/cinefuse
JWT_SECRET=your-32-byte-secret-here
# DO managed Postgres (repo locked down, single maintainer). Use for api component, local dev, migrations, parity tests.
DATABASE_URL=postgres://doadmin:AVNS_2Uuo4SuuMjwE40ZoJlh@app-4b9497da-41df-4013-8248-3f6eb5530082-do-user-10190096-0.l.db.ondigitalocean.com:25060/defaultdb?sslmode=require

# ---- Redis (BullMQ + RQ) ----
REDIS_URL=redis://localhost:6379
CINEFUSE_REDIS_URL=redis://localhost:6379
CINEFUSE_RENDER_QUEUE_KEY=cinefuse:render_jobs
CINEFUSE_WORKER_TOKEN=cinefuse-dev-worker-token

# ---- Render-worker provider keys (M1+) ----
# Leave blank in M0; M1 wires up fal.ai for clip generation.
FAL_API_KEY=
CINEFUSE_CLIP_PROVIDER_URL=
CINEFUSE_CLIP_PROVIDER_TOKEN=
ELEVENLABS_API_KEY=
SUNO_API_KEY=
ANTHROPIC_API_KEY=

# ---- Apple StoreKit (M6) ----
APPLE_BUNDLE_ID=com.pubfuse.cinefuse
APPLE_SHARED_SECRET=
APPLE_VERIFY_RECEIPT_ENV=sandbox

# ---- Observability ----
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
