# Cinefuse environment configuration — copy to .env.local for local dev.
# NEVER commit .env or .env.local. Both are gitignored.

# ---- Pubfuse SDK Client (provisioned at https://www.pubfuse.com/developer) ----
# Cinefuse runs as its own SDK Client; these values authenticate every request
# the cloud makes to Pubfuse on behalf of Cinefuse users.
PUBFUSE_API_BASE_URL=https://api.pubfuse.com
PUBFUSE_APP_ID=Cinefuse
PUBFUSE_CLIENT_ID=
PUBFUSE_CLIENT_SECRET=
PUBFUSE_HMAC_SECRET=

# ---- Cinefuse cloud ----
CINEFUSE_API_BASE_URL=http://localhost:4000
# Dev stub downloads: serves minimal WAV/PNG at GET /api/v1/cinefuse/stub-media/... (disable in production: false).
CINEFUSE_ENABLE_STUB_MEDIA_DOWNLOAD=
# When true (or NODE_ENV=test, or argv contains --test), the audio MCP returns stub score URLs (short sine-tone WAV via stub-media) instead of calling ElevenLabs. Omit for real instrumental sound generation.
# CINEFUSE_ALLOW_STUB_MEDIA=
# MCP audio stub URLs: optional origin so stubs resolve without editing /etc/hosts (same port as api-gateway).
CINEFUSE_GATEWAY_PUBLIC_ORIGIN=http://localhost:4000
CINEFUSE_WEB_BASE_URL=http://localhost:3000
# Optional hosted help docs URL for in-app Help Center.
# When unset or unreachable, Cinefuse uses bundled local help docs.
CINEFUSE_HELP_URL=

# ---- Postgres ----
DATABASE_URL=postgres://cinefuse:cinefuse@localhost:5432/cinefuse
# Optional: explicit DB URL for test runs when CINEFUSE_USE_DB_IN_TESTS=true
DATABASE_URL_TEST=
# Optional TLS knobs for managed Postgres
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
DATABASE_SSL_CA=
# Guardrail: tests default to in-memory unless explicitly enabled
CINEFUSE_USE_DB_IN_TESTS=false
JWT_SECRET=your-32-byte-secret-here

# ---- Redis (BullMQ + RQ) ----
REDIS_URL=redis://localhost:6379
CINEFUSE_REDIS_URL=redis://localhost:6379
CINEFUSE_RENDER_QUEUE_KEY=cinefuse:render_jobs
CINEFUSE_WORKER_TOKEN=cinefuse-dev-worker-token

# ---- Render-worker provider keys (M1+) ----
# Leave blank in M0; M1 wires up fal.ai for clip generation.
FAL_API_KEY=
# Optional bridge endpoint for clip generation (if using your own adapter service)
CINEFUSE_CLIP_PROVIDER_URL=
CINEFUSE_CLIP_PROVIDER_TOKEN=
# Direct fal.ai model routes (used when CINEFUSE_CLIP_PROVIDER_URL is empty)
CINEFUSE_FAL_CLIP_MODEL_BUDGET=
CINEFUSE_FAL_CLIP_MODEL_STANDARD=
CINEFUSE_FAL_CLIP_MODEL_PREMIUM=
CINEFUSE_FAL_MAX_POLL_ATTEMPTS=60
CINEFUSE_FAL_POLL_DELAY_MS=2000

# Audio pipeline adapter (must return sourceUrl + metadata)
CINEFUSE_AUDIO_ADAPTER=generic
CINEFUSE_AUDIO_PROVIDER_URL=
CINEFUSE_AUDIO_PROVIDER_TOKEN=
CINEFUSE_AUDIO_DIALOGUE_PROVIDER_URL=
CINEFUSE_AUDIO_SCORE_PROVIDER_URL=
CINEFUSE_AUDIO_SFX_PROVIDER_URL=
CINEFUSE_AUDIO_MIX_PROVIDER_URL=
CINEFUSE_AUDIO_LIPSYNC_PROVIDER_URL=
# Optional: POST raw audio bytes (e.g. ElevenLabs MP3). Response may be `{ url }` or gateway `{ file: { id, url? } }`.
# When unset, sound jobs use `POST /api/v1/cinefuse/projects/{id}/files` on this gateway if `CINEFUSE_GATEWAY_PUBLIC_ORIGIN` is set (Bearer `user:<owner>` from the render task).
CINEFUSE_AUDIO_UPLOAD_URL=
CINEFUSE_AUDIO_UPLOAD_TOKEN=
# Real ElevenLabs Music (sound shots / score): set ELEVENLABS_API_KEY + CINEFUSE_AUDIO_UPLOAD_URL, and do NOT enable stub mode above. Dialogue TTS also uses ELEVENLABS_API_KEY but requires upload for public URLs.
# Optional: run gateway contract live ElevenLabs test (costs API credits): export CINEFUSE_LIVE_ELEVENLABS_TEST=1 plus keys above, then pnpm --filter @cinefuse/api-gateway contract-test
# CINEFUSE_LIVE_ELEVENLABS_TEST=

# Stitch + Export pipeline adapters
CINEFUSE_STITCH_PROVIDER_URL=
CINEFUSE_STITCH_PROVIDER_TOKEN=
CINEFUSE_EXPORT_PROVIDER_URL=
CINEFUSE_EXPORT_PROVIDER_TOKEN=

# Optional Pubfuse wrapper override for MCP pubfuse server
CINEFUSE_PUBFUSE_API_BASE_URL=
# ElevenLabs (same account for API and the ElevenCreative web app). Restricted keys must list the right scopes:
# - Sounds / instrumental music: POST /v1/music uses permission `music_generation` (dashboard: enable Music / music generation on the key, or turn off "Restrict key").
# - Dialogue TTS: `text_to_speech` (and related). ElevenCreative is the product UI; there is no separate "Creative API key" — only xi-api-key + permissions + a paid plan that includes Music API.
# Optional: default https://api.elevenlabs.io — use regional host if required (e.g. https://api.eu.residency.elevenlabs.io, https://api.us.elevenlabs.io per ElevenLabs dashboard).
# ELEVENLABS_API_BASE_URL=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=
# ElevenLabs Music (Sounds / score): model music_v1; optional output_format (default mp3_44100_128). Higher bitrates may require Creator+ per ElevenLabs docs.
# ELEVENLABS_MUSIC_OUTPUT_FORMAT=mp3_44100_128
SUNO_API_KEY=
ANTHROPIC_API_KEY=

# ---- Apple StoreKit (M6) ----
APPLE_BUNDLE_ID=com.pubfuse.cinefuse
APPLE_SHARED_SECRET=
APPLE_VERIFY_RECEIPT_ENV=sandbox

# ---- Observability ----
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=
