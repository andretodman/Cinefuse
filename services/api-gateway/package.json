{
  "name": "@cinefuse/api-gateway",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "build": "node -e \"console.log('api-gateway build ok')\"",
    "dev": "node src/index.js",
    "lint": "node -e \"console.log('api-gateway lint ok')\"",
    "typecheck": "node -e \"console.log('api-gateway typecheck ok')\"",
    "test": "NODE_ENV=test node --test src/index.test.js src/gateway-public-url.test.js",
    "contract-test": "NODE_ENV=test node --test src/contract.test.js",
    "verify:sound-smoke": "node scripts/smoke-sound-generate.mjs",
    "clean": "node -e \"console.log('api-gateway clean ok')\""
  },
  "dependencies": {
    "pg": "^8.20.0",
    "redis": "^5.12.1"
  }
}
